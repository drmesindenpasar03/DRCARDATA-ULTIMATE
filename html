let flipbookState = { pdfDoc: null, pageNum: 1, isRendering: false, pageNumPending: null, canvas: null, ctx: null, wrapper: null, touchStartX: 0 };

function initHTML5Flipbook(app) {
    let rawUrl = app.content.trim(); let pdfUrl = rawUrl;
    if (rawUrl.includes('drive.google.com')) {
        const driveIdMatch = rawUrl.match(/(?:id=|d\/)([\w-]{25,})/i);
        if (driveIdMatch && driveIdMatch[1]) { pdfUrl = `https://corsproxy.io/?${encodeURIComponent(`https://drive.google.com/uc?export=download&id=${driveIdMatch[1]}`)}`; }
    } else { if (!pdfUrl.includes('corsproxy.io')) { pdfUrl = `https://corsproxy.io/?${encodeURIComponent(pdfUrl)}`; } }

    if (typeof pdfjsLib === 'undefined') {
        const script = document.createElement('script');
        script.src = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/2.16.105/pdf.min.js';
        script.onload = () => {
            pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/2.16.105/pdf.worker.min.js';
            loadPdfDocument(pdfUrl, app, rawUrl);
        };
        document.head.appendChild(script);
    } else {
        loadPdfDocument(pdfUrl, app, rawUrl);
    }
}

function loadPdfDocument(url, app, rawUrl) {
    pdfjsLib.getDocument(url).promise.then(pdf => {
        flipbookState.pdfDoc = pdf; flipbookState.pageNum = 1; renderFlipbookUI(app, rawUrl);
    }).catch(err => {
        console.warn("Flipbook Error/CORS. Fallback to Secure Iframe.", err); renderSecureIframeFallback(app, rawUrl);
    });
}

function handleSwipeStart(e) { flipbookState.touchStartX = e.changedTouches[0].screenX; }
function handleSwipeEnd(e) {
    let touchEndX = e.changedTouches[0].screenX;
    if (touchEndX < flipbookState.touchStartX - 50) flipPage(1); 
    if (touchEndX > flipbookState.touchStartX + 50) flipPage(-1); 
}

function renderFlipbookUI(app, rawUrl) {
    const container = document.getElementById(`pdf-container-${app.id}`);
    if(!container) return;
    container.innerHTML = `
        <div class="flipbook-toolbar">
            <button id="fb-prev" onclick="flipPage(-1)"><i class="fas fa-chevron-left"></i> PREV</button>
            <div class="flipbook-page-info">HALAMAN <span id="fb-page-num">1</span> DARI <span id="fb-page-count">${flipbookState.pdfDoc.numPages}</span></div>
            <button id="fb-next" onclick="flipPage(1)">NEXT <i class="fas fa-chevron-right"></i></button>
        </div>
        <div class="flipbook-viewport" id="fb-viewport">
            <div class="flipbook-canvas-wrapper" id="fb-wrapper"><canvas id="fb-canvas"></canvas></div>
        </div>
    `;
    flipbookState.canvas = document.getElementById('fb-canvas');
    flipbookState.ctx = flipbookState.canvas.getContext('2d', { alpha: false }); 
    flipbookState.wrapper = document.getElementById('fb-wrapper');
    const viewport = document.getElementById('fb-viewport');
    viewport.removeEventListener('touchstart', handleSwipeStart); viewport.removeEventListener('touchend', handleSwipeEnd);
    viewport.addEventListener('touchstart', handleSwipeStart, {passive: true}); viewport.addEventListener('touchend', handleSwipeEnd, {passive: true});
    renderFlipbookPage(flipbookState.pageNum);
}

function renderFlipbookPage(num, direction = 0) {
    flipbookState.isRendering = true;
    flipbookState.pdfDoc.getPage(num).then(page => {
        const viewportEl = document.getElementById('fb-viewport');
        const unscaledViewport = page.getViewport({scale: 1});
        const scale = Math.min((viewportEl.clientWidth - 20) / unscaledViewport.width, (viewportEl.clientHeight - 20) / unscaledViewport.height) * 1.5; 
        const viewport = page.getViewport({scale: scale});
        
        flipbookState.canvas.height = viewport.height; flipbookState.canvas.width = viewport.width;
        flipbookState.canvas.style.width = '100%'; flipbookState.canvas.style.height = '100%'; flipbookState.canvas.style.objectFit = 'contain';

        if (direction !== 0) {
            flipbookState.wrapper.classList.remove('flip-next', 'flip-prev'); void flipbookState.wrapper.offsetWidth;
            flipbookState.wrapper.classList.add(direction > 0 ? 'flip-next' : 'flip-prev');
        }

        page.render({ canvasContext: flipbookState.ctx, viewport: viewport }).promise.then(() => {
            flipbookState.isRendering = false;
            if (flipbookState.pageNumPending !== null) { renderFlipbookPage(flipbookState.pageNumPending); flipbookState.pageNumPending = null; }
        });
        document.getElementById('fb-page-num').textContent = num;
        document.getElementById('fb-prev').disabled = num <= 1; document.getElementById('fb-next').disabled = num >= flipbookState.pdfDoc.numPages;
    });
}

function flipPage(dir) {
    if (flipbookState.isRendering) { flipbookState.pageNumPending = flipbookState.pageNum + dir; return; }
    let newPage = flipbookState.pageNum + dir;
    if (newPage >= 1 && newPage <= flipbookState.pdfDoc.numPages) { flipbookState.pageNum = newPage; renderFlipbookPage(newPage, dir); }
}

