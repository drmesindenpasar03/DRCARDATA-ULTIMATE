function saveNewOrder(container) {
    const tiles = container.querySelectorAll('.tile[data-id], .bottom-tile[data-id]');
    const newOrderIds = Array.from(tiles).map(t => t.getAttribute('data-id'));
    if (newOrderIds.length === 0) return;

    let itemsToReorder = [];
    newOrderIds.forEach(id => { const item = appDictionary[id]; if (item) itemsToReorder.push(item); });
    
    let newAppsData = appsData.filter(a => !newOrderIds.includes(a.id));
    appsData = newAppsData.concat(itemsToReorder); updateAppDictionary();
    
    // DUAL-SYNC DATABASE
    apiRequest('sync_apps', appsData).catch(err => console.error(err));
    if(typeof window.firebaseSyncData === 'function') window.firebaseSyncData('apps', appsData);
}

function renderDynamicApps() {
    const leftPane = document.getElementById('leftPaneContainer'); const rightPane = document.getElementById('rightPaneContainer'); const bottomPane = document.getElementById('bottomPaneContainer');
    if(!leftPane || !rightPane || !bottomPane) return;
    
    let leftHtml = ''; let rightHtml = ''; let bottomHtml = '';
    
    // Urutan warna background icon untuk kotak menu (mengikuti referensi)
    const colorSequence = ['bg-box-red', 'bg-box-blue', 'bg-box-green', 'bg-box-orange'];
    let rightTileCount = 0;
    
    for(let i=0, len=appsData.length; i<len; i++) {
        let app = appsData[i]; if(app.parentId) continue; if(!canAccess(app)) continue;
        
        let accessIcon = '';
        let reqAccess = (app.type && app.type.includes('_')) ? app.type.split('_')[1] : '';
        if (window.currentUser && window.currentUser.role === 'Admin') {
            if (reqAccess === 'PRO') accessIcon = `<i class="fas fa-star" style="position:absolute; top:8px; right:8px; color:silver; font-size:1.1rem; text-shadow:0 0 5px #000; z-index:3;"></i>`;
            if (reqAccess === 'ULTIMATE') accessIcon = `<i class="fas fa-crown" style="position:absolute; top:8px; right:8px; color:gold; font-size:1.1rem; text-shadow:0 0 5px #000; z-index:3;"></i>`;
        }

        let baseType = (app.type && app.type.includes('_')) ? app.type.split('_')[0] : app.type;
        const badgeHtml = app.badge ? `<div class="badge">${app.badge}</div>` : '';
        
        if(baseType === 'large-red') {
            leftHtml += `<div class="tile red-tile" data-id="${app.id}" onclick="openMenu('${app.id}')">${accessIcon}<i class="fas ${app.icon} red-tile-bg-icon bg-icon"></i><i class="fas ${app.icon}"></i><div class="title">${app.title.replace('&', '&<br>')}</div></div>`;
        }
        else if (baseType === 'bottom-tab') {
            bottomHtml += `<div class="tile bottom-tile" data-id="${app.id}" onclick="openMenu('${app.id}')">${accessIcon}${badgeHtml}<i class="fas ${app.icon} bottom-tile-bg-icon bg-icon"></i><i class="fas ${app.icon}"></i><div class="title">${app.title}</div></div>`;
        }
        else {
            // Terapkan box warna warni untuk menu-menu reguler di sebelah kanan
            let colorClass = colorSequence[rightTileCount % colorSequence.length];
            rightHtml += `<div class="tile" data-id="${app.id}" onclick="openMenu('${app.id}')">${accessIcon}${badgeHtml}<div class="icon-box ${colorClass}"><i class="fas ${app.icon}"></i></div><div class="title">${app.title}</div></div>`;
            rightTileCount++;
        }
    }

    if(window.currentUser && window.currentUser.role === 'Admin') rightHtml += `<div class="tile add-tile" onclick="openAdminPanel()"><i class="fas fa-plus"></i></div>`;

    leftPane.innerHTML = leftHtml; rightPane.innerHTML = rightHtml; bottomPane.innerHTML = bottomHtml;
    
    if(window.currentUser && window.currentUser.role === 'Admin') {
        Sortable.create(rightPane, { animation: 150, delay: 150, delayOnTouchOnly: true, filter: '.add-tile', ghostClass: 'sortable-ghost', fallbackOnBody: true, onStart: function() { isDraggingTile = true; }, onEnd: function(evt) { setTimeout(() => isDraggingTile = false, 50); if(evt.oldIndex !== evt.newIndex) saveNewOrder(rightPane); } });
        Sortable.create(bottomPane, { animation: 150, delay: 150, delayOnTouchOnly: true, ghostClass: 'sortable-ghost', fallbackOnBody: true, onStart: function() { isDraggingTile = true; }, onEnd: function(evt) { setTimeout(() => isDraggingTile = false, 50); if(evt.oldIndex !== evt.newIndex) saveNewOrder(bottomPane); } });
    }
}

