                document.getElementById('ctxAccessPub').style.display = 'flex'; document.getElementById('ctxAccessPro').style.display = 'flex'; document.getElementById('ctxAccessUlt').style.display = 'flex';
                document.getElementById('ctxAccessPub').innerHTML = `<i class="fas fa-globe"></i> Akses: Semua Member ${reqAccess==='' ? '<i class="fas fa-check" style="margin-left:auto;color:#10b981;"></i>' : ''}`;
