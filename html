<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>DrCardata PRO - Advanced System</title>
    
    <link rel="preconnect" href="https://cdnjs.cloudflare.com">
    <link rel="preconnect" href="https://translate.googleapis.com">
    
    <link rel="preload" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
    <noscript><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"></noscript>
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>

    <!-- Library SheetJS untuk Ekspor & Impor Excel -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>

    <style>
        :root {
            --bg-color: #080808;
            --surface-color: #1a1a1a;
            --surface-hover: #262626;
            --border-color: #333333;
            --primary-red: #e60000;
            --primary-dark: #b30000;
            --text-main: #ffffff;
            --text-muted: #aaaaaa;
        }

        *, *::before, *::after { box-sizing: border-box; }

        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.2); border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: var(--primary-red); }

        /* ANTI-COPY & ANTI-SELECT KECUALI INPUT */
        body, html {
            margin: 0; padding: 0; width: 100%; height: 100vh; height: 100dvh;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--bg-color);
            color: var(--text-main);
            overflow: hidden; 
            overscroll-behavior-y: none;
            -webkit-tap-highlight-color: transparent;
            touch-action: manipulation;
            -webkit-user-select: none;
            -moz-user-select: none;
            -ms-user-select: none;
            user-select: none;
        }

        input, textarea, select {
            -webkit-user-select: auto;
            -moz-user-select: auto;
            -ms-user-select: auto;
            user-select: auto;
        }

        button, .admin-tab, .tile, .icon-item, .context-menu-item { touch-action: manipulation; }

        .bg-animated {
            position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; height: 100dvh; z-index: 0;
            background: radial-gradient(circle at 50% 50%, #1a0000 0%, #050505 100%);
            background-size: 200% 200%;
            animation: gradientShift 15s ease infinite; 
            transform: translateZ(0);
            will-change: background-position;
        }
        .bg-grid {
            position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; height: 100dvh; z-index: 1;
            background-image: linear-gradient(rgba(230, 0, 0, 0.1) 1px, transparent 1px), linear-gradient(90deg, rgba(230, 0, 0, 0.1) 1px, transparent 1px);
            background-size: 40px 40px; pointer-events: none; box-shadow: inset 0 0 100px #000;
        }
        @keyframes gradientShift { 0%{background-position:0% 50%} 50%{background-position:100% 50%} 100%{background-position:0% 50%} }

        .header-widget, .sidebar, .footer, .fauxcolumn-outer { display: none !important; }
        #BloggerAppContainer {
            position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; height: 100dvh;
            z-index: 999999; display: flex; flex-direction: column;
            overflow-y: auto; overflow-x: hidden; background: transparent;
        }

        /* HEADER UI TERBARU */
        .app-header {
            background: rgba(15, 15, 15, 0.98); color: #fff; padding: 12px 20px; display: flex; justify-content: space-between;
            align-items: center; border-bottom: 2px solid var(--primary-red); flex-shrink: 0; z-index: 100; gap: 10px; position: relative;
        }
        .app-header .header-left { display: flex; align-items: center; gap: 12px; flex: 1; }
        
        /* Animasi Hidup untuk Logo Header */
        @keyframes headerIconPulse {
            0% { transform: scale(1); filter: drop-shadow(0 0 2px rgba(230,0,0,0.4)); }
            50% { transform: scale(1.15); filter: drop-shadow(0 0 12px rgba(230,0,0,0.8)); }
            100% { transform: scale(1); filter: drop-shadow(0 0 2px rgba(230,0,0,0.4)); }
        }
        .app-header .header-left i { 
            font-size: 2.2rem; 
            color: var(--primary-red); 
            animation: headerIconPulse 2.5s infinite ease-in-out; 
            will-change: transform, filter;
        }
        
        .app-header .header-logo-container { display: flex; flex-direction: column; justify-content: center; }
        .app-header .top-text { font-size: 0.95rem; font-weight: 800; color: #ddd; letter-spacing: 1px; line-height: 1.2; text-transform: uppercase; }
        .app-header .bottom-text { font-size: 0.65rem; color: #888; letter-spacing: 1px; text-transform: uppercase; margin-top: 2px; }
        
        .app-header .header-center { position: absolute; left: 50%; transform: translateX(-50%); display: flex; justify-content: center; align-items: center; pointer-events: none; }
        .app-header .header-logo { color: #fff; font-size: 1.8rem; font-weight: 900; letter-spacing: 1.5px; white-space: nowrap; line-height: 1; }
        .app-header .header-logo span { color: var(--primary-red); }
        
        .app-header .header-right { display: flex; align-items: center; gap: 10px; font-size: 1rem; flex-wrap: wrap; justify-content: flex-end; flex: 1; }
        
        /* Tombol Outline Style */
        .translate-wrapper {
            position: relative; width: 36px; height: 36px; display: flex; justify-content: center; align-items: center;
            background: transparent; border: 1px solid rgba(255,255,255,0.2); border-radius: 6px;
            cursor: pointer; transition: 0.2s; overflow: hidden;
        }
        .translate-wrapper:hover { background: rgba(255,255,255,0.05); border-color: var(--primary-red); }
        .translate-wrapper i { color: #fff; font-size: 1.1rem; pointer-events: none; z-index: 1; transition: 0.2s; }
        #google_translate_element { position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 2; opacity: 0.01; }
        .goog-te-gadget { font-size: 0px !important; color: transparent !important; width: 100%; height: 100%; }
        .goog-te-gadget .goog-te-combo { position: absolute; top: 0; left: 0; width: 100%; height: 100%; cursor: pointer; margin: 0; opacity: 0; }
        .goog-te-banner-frame.skiptranslate, .goog-te-gadget-icon { display: none !important; }
        body { top: 0px !important; }

        .btn-chat-header, .btn-profile { background: transparent; border: 1px solid rgba(255,255,255,0.2); border-radius: 6px; color: #fff; cursor: pointer; display:flex; align-items:center; justify-content:center; transition: 0.2s;}
        .btn-chat-header:hover, .btn-profile:hover { background: rgba(255,255,255,0.05); border-color: var(--primary-red); }
        .btn-chat-header { width: 36px; height: 36px; flex-shrink: 0;}
        .btn-profile { padding: 6px 12px; font-size: 0.95rem; gap: 8px; font-weight: 600; white-space: nowrap; height: 36px; }
        
        .btn-logout { background: transparent; border: 1px solid rgba(230,0,0,0.3); color: var(--primary-red); cursor: pointer; font-size: 1.2rem; width: 36px; height: 36px; border-radius: 6px; display: flex; justify-content: center; align-items: center; transition: 0.2s;}
        .btn-logout:hover { background: rgba(230,0,0,0.1); border-color: var(--primary-red); transform: scale(1.05); }

        /* SPLASH SCREEN KUSTOM BARU */
        #welcomeScreen {
            position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; height: 100dvh;
            background: radial-gradient(circle at center, #1a0000 0%, #050505 100%);
            z-index: 9999999; display: flex; justify-content: center; align-items: center; flex-direction: column;
            transition: opacity 0.6s ease-out, transform 0.6s ease-out;
        }
        .splash-content { text-align: center; animation: splashFadeUp 0.8s ease-out forwards; }
        .splash-logo-wrapper { 
            width: 110px; height: 110px; margin: 0 auto 20px; 
            background: rgba(230, 0, 0, 0.05); border: 2px solid var(--primary-red);
            border-radius: 50%; display: flex; justify-content: center; align-items: center;
            box-shadow: 0 0 30px rgba(230, 0, 0, 0.3);
            animation: splashPulse 2s infinite;
        }
        .splash-icon { font-size: 3.5rem; color: var(--primary-red); text-shadow: 0 0 15px rgba(230,0,0,0.8); }
        .splash-title { margin: 0; font-size: 2.5rem; font-weight: 800; color: #fff; letter-spacing: 2px; }
        .splash-title span { color: var(--primary-red); }
        .splash-subtitle { margin: 5px 0 35px 0; font-size: 0.85rem; color: var(--text-muted); letter-spacing: 4px; font-weight: 600; }
        
        .splash-loader { width: 250px; height: 4px; background: #222; border-radius: 2px; margin: 0 auto; overflow: hidden; position: relative;}
        .splash-progress { width: 0%; height: 100%; background: var(--primary-red); animation: splashLoad 2.2s cubic-bezier(0.4, 0, 0.2, 1) forwards; box-shadow: 0 0 10px var(--primary-red);}
        .splash-status { margin-top: 15px; font-size: 0.8rem; color: var(--primary-red); font-weight: bold; letter-spacing: 2px; animation: blink 1.5s infinite; }
        .splash-footer { position: absolute; bottom: 30px; font-size: 0.75rem; color: #444; letter-spacing: 2px; }

        @keyframes splashFadeUp { 0% { opacity: 0; transform: translateY(30px); } 100% { opacity: 1; transform: translateY(0); } }
        @keyframes splashPulse { 0% { box-shadow: 0 0 15px rgba(230,0,0,0.2); } 50% { box-shadow: 0 0 40px rgba(230,0,0,0.6); } 100% { box-shadow: 0 0 15px rgba(230,0,0,0.2); } }
        @keyframes splashLoad { 0% { width: 0%; } 20% { width: 30%; } 60% { width: 75%; } 100% { width: 100%; } }

        /* LAYOUT LOGIN & REGISTER */
        .center-screen { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100vh; height: 100dvh; position: relative; z-index: 10; padding: 15px;}
        .login-box {
            background: rgba(20, 20, 20, 0.98); border: 1px solid var(--border-color); padding: 30px; border-radius: 12px; box-shadow: 0 10px 30px rgba(0,0,0,0.9);
            width: 100%; max-width: 380px; text-align: center; color: white; transition: all 0.3s ease; position: relative; overflow: hidden; transform: translateZ(0);
        }
        .login-box.active { padding: 40px 35px; }
        .login-box::before { content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 4px; background: var(--primary-red); }
        .login-logo-container { cursor: pointer; transition: all 0.3s ease; padding: 10px; }
        .login-logo { font-size: 4rem; color: var(--primary-red); margin-bottom: 15px; }
        .login-box.active .login-logo-container { transform: scale(0.65) translateY(-15px); margin-bottom: -35px; }
        .click-hint { font-size: 0.85rem; color: var(--primary-red); letter-spacing: 2px; font-weight: bold; animation: blink 1.5s infinite; }
        .login-box.active .click-hint { opacity: 0; max-height: 0; overflow: hidden; }
        @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }

        .login-form-wrap { max-height: 0; opacity: 0; overflow: hidden; transition: all 0.4s ease; transform: translateY(-10px); }
        .login-box.active .login-form-wrap { max-height: 800px; opacity: 1; transform: translateY(0); margin-top: 15px; overflow-y: auto; }
        .login-box h2 { font-weight: 700; letter-spacing: 2px; margin: 0 0 25px 0; font-size: 1.5rem; color: #fff;}
        .input-group { margin-bottom: 20px; text-align: left; position: relative; }
        .input-group i { position: absolute; top: 14px; left: 15px; color: var(--text-muted); font-size: 1.1rem; transition: 0.3s; }
        .input-group input { width: 100%; padding: 12px 12px 12px 42px; border: 1px solid var(--border-color); background: rgba(0,0,0,0.8); color: white; border-radius: 6px; box-sizing: border-box; font-size: 16px; transition: 0.2s; }
        .input-group input:focus { outline: none; border-color: var(--primary-red); background: #000; }
        .input-group input:focus + i { color: var(--primary-red); }
        
        .btn-login { background: var(--primary-red); color: white; border: none; padding: 14px; width: 100%; border-radius: 6px; font-size: 1.1rem; cursor: pointer; font-weight: bold; letter-spacing: 1px; transition: 0.2s; display: flex; justify-content: center; align-items: center; gap: 10px; }
        .btn-login:hover { background: var(--primary-dark); }
        .btn-wa { background: #25D366; color: white; border: none; padding: 12px; width: 100%; border-radius: 6px; font-size: 1.1rem; cursor: pointer; font-weight: bold; display: flex; align-items: center; justify-content: center; gap: 8px; margin-top: 15px; transition: 0.2s;}
        .btn-wa:hover { filter: brightness(1.1); }

        .link-text { color: var(--text-muted); font-size: 0.9rem; margin-top: 20px; cursor: pointer; transition: 0.2s; }
        .link-text span { color: var(--primary-red); font-weight: bold; text-decoration: underline; }
        .link-text:hover span { color: #fff; }

        /* KARTU PAKET REGISTRASI (FUTURISTIC & ELEGANT) */
        #registerBox { max-width: 780px; display: none; width: 95%; }
        #registerBox.active { padding: 35px; }
        
        .register-input-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; }
        .register-input-grid .input-group { margin-bottom: 0; }
        
        .package-section-title {
            text-align: left; margin: 25px 0 15px 0; font-weight: 800; color: #fff; font-size: 0.95rem; letter-spacing: 2px;
            display: flex; align-items: center; gap: 10px; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 10px;
        }
        .package-section-title i { color: var(--primary-red); font-size: 1.2rem; }

        #dynamicPackageSelector { 
            display: grid; 
            grid-template-columns: repeat(3, 1fr); 
            gap: 15px; 
            margin-bottom: 25px; 
            width: 100%;
        }

        .pkg-card {
            background: linear-gradient(180deg, rgba(20,20,20,0.95) 0%, rgba(5,5,5,0.98) 100%);
            border: 1px solid rgba(230,0,0,0.15);
            border-top: 3px solid rgba(230,0,0,0.4);
            border-radius: 8px;
            padding: 20px 15px;
            position: relative;
            cursor: pointer;
            overflow: hidden;
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
            gap: 12px;
        }

        /* Scanline Overlay Futuristik */
        .pkg-card::after {
            content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            background: linear-gradient(rgba(230,0,0,0.04) 1px, transparent 1px);
            background-size: 100% 3px; pointer-events: none; opacity: 0.6;
        }

        /* Animasi Sweep Cahaya */
        .pkg-card::before {
            content: ''; position: absolute; top: -100%; left: 0; width: 100%; height: 50%;
            background: linear-gradient(to bottom, transparent, rgba(230,0,0,0.15), transparent);
            transition: top 0.6s ease-in-out; pointer-events: none;
        }

        .pkg-card:hover {
            border-color: rgba(230,0,0,0.6);
            transform: translateY(-8px);
            box-shadow: 0 12px 25px rgba(0,0,0,0.7), 0 0 15px rgba(230,0,0,0.2);
        }
        .pkg-card:hover::before { top: 100%; }

        .pkg-card.selected {
            border-color: var(--primary-red);
            border-top-color: var(--primary-red);
            background: linear-gradient(180deg, rgba(50,0,0,0.4) 0%, rgba(10,0,0,0.9) 100%);
            box-shadow: 0 0 25px rgba(230,0,0,0.5), inset 0 0 20px rgba(230,0,0,0.3);
            transform: translateY(-5px) scale(1.03);
            z-index: 2;
        }

        .pkg-header { display: flex; flex-direction: column; align-items: center; gap: 8px; z-index: 2; width: 100%; }
        .pkg-title { font-size: 1.05rem; font-weight: 800; color: #fff; letter-spacing: 1px; text-transform: uppercase; margin: 0; }
        
        .pkg-role-badge { 
            font-size: 0.65rem; background: rgba(230,0,0,0.1); padding: 4px 10px; border-radius: 20px; 
            color: var(--text-muted); border: 1px solid rgba(230,0,0,0.2); text-transform: uppercase; letter-spacing: 1.5px; 
            transition: 0.3s;
        }
        .pkg-card.selected .pkg-role-badge { background: var(--primary-red); color: #fff; border-color: var(--primary-red); font-weight: bold; box-shadow: 0 0 10px rgba(230,0,0,0.5); }

        .pkg-price { font-size: 1.25rem; font-weight: 900; color: var(--primary-red); letter-spacing: 1px; z-index: 2; margin: 5px 0; transition: 0.3s; }
        .pkg-card.selected .pkg-price { text-shadow: 0 0 15px rgba(230,0,0,0.8); color: #fff; }

        .pkg-desc { font-size: 0.8rem; color: #aaa; line-height: 1.5; border-top: 1px dashed rgba(230,0,0,0.2); padding-top: 12px; z-index: 2; width: 100%; }
        .pkg-card.selected .pkg-desc { color: #ddd; border-top-color: rgba(255,255,255,0.2); }

        .pkg-check-icon {
            position: absolute; top: 12px; right: 12px; transform: scale(0);
            color: var(--primary-red); font-size: 1.5rem; opacity: 0; 
            transition: 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            text-shadow: 0 0 15px rgba(230,0,0,0.8); z-index: 3;
        }
        .pkg-card.selected .pkg-check-icon { opacity: 1; transform: scale(1); }

        /* Penyesuaian HP: Geser Menyamping (Horizontal Swipe) */
        @media (max-width: 768px) {
            #registerBox { max-width: 100%; }
            #dynamicPackageSelector {
                display: flex; overflow-x: auto; scroll-snap-type: x mandatory;
                padding-bottom: 20px; -webkit-overflow-scrolling: touch;
                scrollbar-width: none; 
                margin-left: -10px; margin-right: -10px; padding-left: 10px; padding-right: 10px;
            }
            #dynamicPackageSelector::-webkit-scrollbar { display: none; } 
            .pkg-card { flex: 0 0 82%; scroll-snap-align: center; }
        }

        @media (max-width: 500px) {
            .register-input-grid { grid-template-columns: 1fr; gap: 12px; }
            #registerBox.active { padding: 25px 20px; }
            .pkg-card { flex: 0 0 88%; }
        }

        /* DASHBOARD LAYOUT BARU */
        #dashboardScreen { display: none; padding: 20px; flex: 1; overflow-y: auto; position: relative; z-index: 10; -webkit-overflow-scrolling: touch;}
        .dashboard-wrapper { display: flex; flex-direction: column; gap: 20px; max-width: 1400px; margin: 0 auto; min-height: 100%; }
        .dashboard-main { display: flex; gap: 20px; flex: 1; align-items: stretch; }
        .left-pane { flex: 0 0 25%; display: flex; flex-direction: column; gap: 15px; }
        .right-pane { flex: 1; display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); grid-auto-rows: minmax(120px, 1fr); gap: 15px; align-content: start; }
        
        /* CSS TAB BAWAH */
        .bottom-pane { display: grid; grid-template-columns: repeat(4, 1fr); gap: 15px; width: 100%; flex-shrink: 0; padding-bottom: 5px; }

        .tile {
            background: linear-gradient(135deg, rgba(45, 48, 55, 0.95) 0%, rgba(25, 28, 35, 0.95) 100%); 
            border: 1px solid #3a3f4a; border-radius: 12px; display: flex; flex-direction: column; align-items: center; justify-content: center;
            cursor: pointer; position: relative; text-align: center; padding: 15px 10px; transition: transform 0.15s ease, background 0.2s, border-color 0.2s; transform: translateZ(0);
            box-shadow: 0 4px 15px rgba(0,0,0,0.4); overflow: hidden;
        }
        .tile:active { transform: scale(0.95); }
        .tile:hover { background: linear-gradient(135deg, rgba(55, 58, 65, 0.98) 0%, rgba(35, 38, 45, 0.98) 100%); border-color: #5a5f6a; transform: scale(1.03); }
        .tile i:not(.bg-icon) { font-size: 2.5rem; margin-bottom: 12px; color: #ddd; transition: color 0.2s; position: relative; z-index: 2; }
        .tile:hover i:not(.bg-icon) { color: #fff; }
        .tile .title { font-size: 0.85rem; font-weight: 600; color: #e0e0e0; line-height: 1.3; word-wrap: break-word; position: relative; z-index: 2; text-transform: uppercase;}
        
        /* Box Ikon Warna-Warni ala Capture_2.jpg */
        .icon-box {
            width: 55px; height: 55px; border-radius: 14px;
            display: flex; justify-content: center; align-items: center;
            margin-bottom: 12px; position: relative; z-index: 2;
            box-shadow: inset 0 2px 5px rgba(255,255,255,0.25), 0 5px 10px rgba(0,0,0,0.3);
        }
        .icon-box i:not(.bg-icon) { font-size: 1.8rem !important; color: #fff !important; margin-bottom: 0 !important; }
        
        .bg-box-red { background: linear-gradient(135deg, #ef5350, #c62828); }
        .bg-box-blue { background: linear-gradient(135deg, #42a5f5, #1565c0); }
        .bg-box-green { background: linear-gradient(135deg, #66bb6a, #2e7d32); }
        .bg-box-orange { background: linear-gradient(135deg, #ffa726, #ef6c00); }

        .sortable-ghost { opacity: 0.4; border: 2px dashed #666 !important; background: rgba(0,0,0,0.8) !important; }
        
        /* Tile Utama (Kiri) - INTELLIGENT DIAGNOSE dgn Glowing Hijau */
        .tile.red-tile { 
            background: linear-gradient(135deg, rgba(20, 35, 30, 0.8) 0%, rgba(10, 20, 15, 0.95) 100%); 
            border: 1px solid #4caf50; flex: 1; min-height: 140px; 
            box-shadow: 0 4px 15px rgba(0,0,0,0.5), inset 0 -4px 20px rgba(76, 175, 80, 0.15);
        }
        .tile.red-tile:hover { 
            background: linear-gradient(135deg, rgba(30, 45, 40, 0.9) 0%, rgba(15, 25, 20, 1) 100%); 
            border-color: #81c784; 
            box-shadow: 0 4px 15px rgba(0,0,0,0.6), inset 0 -4px 25px rgba(76, 175, 80, 0.3);
        }
        .tile.red-tile i:not(.bg-icon) { font-size: 3.5rem !important; color: #fff !important; margin-bottom: 15px !important;}
        .tile.red-tile .title { font-size: 1.15rem; color: white; letter-spacing: 1px;}
        
        /* Ikon Background Animasi Premium */
        .bg-icon {
            position: absolute !important;
            bottom: -20px !important;
            right: -20px !important;
            color: rgba(255, 255, 255, 0.05) !important;
            pointer-events: none;
            z-index: 1;
            margin-bottom: 0 !important;
        }
        .red-tile-bg-icon { font-size: 7.5rem !important; animation: animateBgIconDefault 6s ease-in-out infinite; }
        .tile.red-tile:hover .red-tile-bg-icon { animation: animateBgIconHoverRed 3s ease-in-out infinite; }

        .bottom-tile-bg-icon { font-size: 6rem !important; animation: animateBgIconDefault 8s ease-in-out infinite reverse; }
        .tile.bottom-tile:hover .bottom-tile-bg-icon { animation: animateBgIconHoverBottom 3.5s ease-in-out infinite reverse; }

        @keyframes animateBgIconDefault {
