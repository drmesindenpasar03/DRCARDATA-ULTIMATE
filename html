window.jumpToMenuLevel = function(idx) { menuStack = menuStack.slice(0, idx + 1); renderCurrentMenuState(); }

function renderCurrentMenuState() {
    if(menuStack.length === 0) return;
    requestAnimationFrame(() => {
        const currentApp = menuStack[menuStack.length - 1]; 
        
        let breadcrumbHtml = menuStack.map((app, idx) => {
            if (idx === menuStack.length - 1) return `<span style="color:#fff;">${app.title}</span>`;
            return `<span style="color:var(--text-muted); cursor:pointer;" onclick="jumpToMenuLevel(${idx})">${app.title}</span>`;
        }).join(' <i class="fas fa-angle-right" style="color:var(--primary-red); font-size:0.9rem; margin:0 8px;"></i> ');
        
        document.getElementById('detailTitle').innerHTML = breadcrumbHtml;
        const detailContent = document.getElementById('detailContent');
        
        currentZoomLevel = 1;
        const zoomLabel = document.getElementById('zoomLabel'); if(zoomLabel) zoomLabel.innerText = '100%';
        detailContent.style.zoom = 1; detailContent.style.transform = 'none';
        detailContent.innerHTML = buildContentHtml(currentApp);
        
        const zoomCtrl = document.getElementById('smartZoomCtrl');
        
        // Kembalikan posisi panel zoom control ke setting awal (Bottom Right) saat ganti menu
        if (zoomCtrl) {
            zoomCtrl.style.left = '';
            zoomCtrl.style.top = '';
            zoomCtrl.style.bottom = '';
            zoomCtrl.style.right = '';
            zoomCtrl.style.transform = '';
            zoomCtrl.style.transition = '';
        }

        if (['pdf', 'web', 'image', 'mp4'].includes(currentApp.contentType)) {
            document.getElementById('detailScreen').classList.add('immersive-mode');
            if(zoomCtrl) zoomCtrl.classList.add('visible');
            detailContent.style.padding = '0'; detailContent.style.overflow = 'hidden'; detailContent.style.touchAction = 'none';
            if (['image', 'mp4'].includes(currentApp.contentType)) detailContent.style.backgroundColor = '#000'; else detailContent.style.backgroundColor = 'transparent';
            if (currentApp.contentType === 'pdf') {
                let urlCheck = currentApp.content.toLowerCase();
                if (urlCheck.match(/\.(doc|docx|ppt|pptx|xls|xlsx)(\?|$)/)) renderSecureIframeFallback(currentApp, currentApp.content);
                else initHTML5Flipbook(currentApp);
            }
        } else {
            document.getElementById('detailScreen').classList.remove('immersive-mode');
            document.querySelector('#detailScreen .detail-header').classList.remove('visible');
            if(zoomCtrl) zoomCtrl.classList.remove('visible');
            detailContent.style.padding = '20px'; detailContent.style.overflow = 'auto'; detailContent.style.backgroundColor = 'transparent';
            if(window.innerWidth <= 480) { const fGrid = document.querySelector('.folder-grid-responsive'); if(fGrid) fGrid.style.gridTemplateColumns = 'repeat(auto-fill, minmax(95px, 1fr))'; }
        }

        const btnOpenOutside = document.getElementById('btnOpenOutside');
        if(currentApp.contentType === 'web') {
            let safeWebUrl = currentApp.content.trim(); if (!safeWebUrl.startsWith('http://') && !safeWebUrl.startsWith('https://')) safeWebUrl = 'https://' + safeWebUrl;
            btnOpenOutside.style.display = 'flex'; btnOpenOutside.onclick = function() { window.open(safeWebUrl, '_blank'); };
        } else { btnOpenOutside.style.display = 'none'; }
        
        const detailScreen = document.getElementById('detailScreen');
        if(detailScreen.style.display !== 'flex') { detailScreen.style.display = 'flex'; document.getElementById('dashboardScreen').style.display = 'none'; }
        if(detailScreen.classList.contains('immersive-mode')) showHeaderBriefly();

        if (currentApp.contentType === 'folder' && window.currentUser && window.currentUser.role === 'Admin') {
            const grid = document.getElementById(`folderGrid_${currentApp.id}`);
            if (grid) {
                Sortable.create(grid, { animation: 150, delay: 150, delayOnTouchOnly: true, ghostClass: 'sortable-ghost', fallbackOnBody: true, onStart: function() { isDraggingTile = true; }, onEnd: function(evt) { setTimeout(() => isDraggingTile = false, 50); if(evt.oldIndex !== evt.newIndex) saveNewOrder(grid); } });
            }
        }
    });
}

let quickCreateParentId = null; let rightClickedAppId = null; 
document.addEventListener('contextmenu', function(e) {
    const isInput = e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA';
    if (!isInput) e.preventDefault(); 
    
    if (!window.currentUser || window.currentUser.role !== 'Admin') return; 
    const isDashboard = e.target.closest('#dashboardScreen'); const isDetail = e.target.closest('#detailContent'); const tile = e.target.closest('.tile'); 
    
    if (isDashboard || isDetail) {
        rightClickedAppId = null;
        document.getElementById('ctxEdit').style.display = 'none'; document.getElementById('ctxDel').style.display = 'none';
        document.getElementById('ctxAccessPub').style.display = 'none'; document.getElementById('ctxAccessPro').style.display = 'none'; document.getElementById('ctxAccessUlt').style.display = 'none';

        if (tile && tile.getAttribute('data-id')) {
            rightClickedAppId = tile.getAttribute('data-id');
            document.getElementById('ctxEdit').style.display = 'flex'; document.getElementById('ctxDel').style.display = 'flex';
            let clickedApp = appDictionary[rightClickedAppId];
            if (clickedApp) {
