                document.getElementById('ctxAccessUlt').innerHTML = `<i class="fas fa-crown" style="color:gold;"></i> Akses: Khusus ULTIMATE ${reqAccess==='ULTIMATE' ? '<i class="fas fa-check" style="margin-left:auto;color:#10b981;"></i>' : ''}`;
            }
        }
        if (isDetail && menuStack.length > 0) { quickCreateParentId = menuStack[menuStack.length - 1].id; } else { quickCreateParentId = ""; }

        const menu = document.getElementById('adminContextMenu'); if (!menu) return; 
        menu.style.display = 'block';
        let x = e.clientX; let y = e.clientY;
        if(x + 240 > window.innerWidth) x = window.innerWidth - 250; if(y + 240 > window.innerHeight) y = window.innerHeight - 250;
        menu.style.left = x + 'px'; menu.style.top = y + 'px';
    }
});

