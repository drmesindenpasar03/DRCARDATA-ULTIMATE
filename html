        setTimeout(() => { splashStatus.innerText = "SYSTEM READY"; splashStatus.style.color = "#10b981"; }, 2200);
    }
    setTimeout(() => {
        const splash = document.getElementById('welcomeScreen');
        if (splash) {
            splash.style.opacity = '0'; splash.style.transform = 'scale(1.1)'; 
            setTimeout(() => { splash.style.display = 'none'; document.getElementById('loginScreen').style.display = 'flex'; revealLogin(); }, 600); 
        }
    }, 2600); 

    // Muat Billing Config Offline Awal (Jika DB lambat)
    renderRegistrationPackages();

    // ==========================================
    // LOGIKA DRAG & DROP ZOOM CONTROL
    // ==========================================
    const zoomCtrl = document.getElementById('smartZoomCtrl');
    let isDraggingZoom = false;
    let zoomOffsetX, zoomOffsetY;

    if(zoomCtrl) {
        zoomCtrl.addEventListener('mousedown', startDragZoom);
        zoomCtrl.addEventListener('touchstart', startDragZoom, {passive: false});
    }

    function startDragZoom(e) {
        if (e.target.tagName.toLowerCase() === 'button' || e.target.closest('button')) return; 
        e.preventDefault(); 
        isDraggingZoom = true;
        zoomCtrl.style.cursor = 'grabbing';
        
        let clientX = e.type.includes('mouse') ? e.clientX : e.touches[0].clientX;
        let clientY = e.type.includes('mouse') ? e.clientY : e.touches[0].clientY;
        
        const rect = zoomCtrl.getBoundingClientRect();
        zoomOffsetX = clientX - rect.left;
        zoomOffsetY = clientY - rect.top;
        
        // Lepaskan kaitan posisi bottom/right, biarkan absolute berdasarkan left/top
        zoomCtrl.style.bottom = 'auto';
        zoomCtrl.style.right = 'auto';
        zoomCtrl.style.left = rect.left + 'px';
        zoomCtrl.style.top = rect.top + 'px';
        zoomCtrl.style.transform = 'none'; 
        zoomCtrl.style.transition = 'none'; 
        
        document.addEventListener('mousemove', dragZoom);
        document.addEventListener('touchmove', dragZoom, {passive: false});
        document.addEventListener('mouseup', endDragZoom);
        document.addEventListener('touchend', endDragZoom);
    }

    function dragZoom(e) {
        if (!isDraggingZoom) return;
        e.preventDefault(); // Mencegah layar ikut terscroll
        let clientX = e.type.includes('mouse') ? e.clientX : e.touches[0].clientX;
        let clientY = e.type.includes('mouse') ? e.clientY : e.touches[0].clientY;
        
        zoomCtrl.style.left = (clientX - zoomOffsetX) + 'px';
        zoomCtrl.style.top = (clientY - zoomOffsetY) + 'px';
    }

    function endDragZoom() {
        if (!isDraggingZoom) return;
        isDraggingZoom = false;
        zoomCtrl.style.cursor = 'grab';
        document.removeEventListener('mousemove', dragZoom);
        document.removeEventListener('touchmove', dragZoom);
        document.removeEventListener('mouseup', endDragZoom);
        document.removeEventListener('touchend', endDragZoom);
    }
});

