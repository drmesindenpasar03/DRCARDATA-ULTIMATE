function getDaysRemaining(expDateStr) {
    if(!expDateStr) return 0;
    const exp = new Date(expDateStr); const today = new Date();
    return Math.ceil((exp - today) / (1000 * 60 * 60 * 24));
}

window.prosesLogin = async function() {
    const user = document.getElementById('username').value.trim();
    const pass = document.getElementById('password').value.trim();
    
    if(!user || !pass) return appAlert("System ID dan Password wajib diisi!", "Authentication Error", "error");
    if(!IS_PREVIEW && (!GAS_URL || GAS_URL.includes("URL_DEPLOY"))) return appAlert("Sistem belum dihubungkan ke Database.", "Warning", "warning");

    document.getElementById('loadingOverlay').style.display = 'flex';
    const data = await apiRequest('login', { user: user, pass: pass, deviceId: window.deviceId });
    document.getElementById('loadingOverlay').style.display = 'none';
    
    if(data.success) {
        if(getDaysRemaining(data.user.exp) < 0) {
            document.getElementById('expiredUsername').innerText = data.user.username;
            document.getElementById('loginScreen').style.display = 'none';
            document.getElementById('expiredScreen').style.display = 'flex';
            return;
        }
        
        appsData = data.apps || []; updateAppDictionary(); 
        usersData = data.allUsers || [];
        headerConfig = data.config || headerConfig;
        
        loginSuccess(data.user);
    } else { appAlert("Akses Ditolak: " + data.message, "Security Alert", "error"); }
}

