function getAppBreadcrumbOpt(appId) {
    let path = []; let currId = appId; let safeguard = 0; 
    while(currId && appDictionary[currId] && safeguard < 20) { path.unshift(appDictionary[currId].title); currId = appDictionary[currId].parentId; safeguard++; }
    return path.join(' > ');
}

function isDescendantOpt(childId, parentId) {
    let currId = childId; let safeguard = 0;
    while(currId && appDictionary[currId] && safeguard < 20) {
        if(currId === parentId || appDictionary[currId].parentId === parentId) return true;
        currId = appDictionary[currId].parentId; safeguard++;
    } return false;
}

window.renderAdminAppTable = function() {
    updateAppDictionary(); window.updateAdminAppFilterDropdown();
    const tbody = document.getElementById('appTableBody'); const filterVal = document.getElementById('adminAppFilter').value;
    let sortedApps = [...appsData].map((app, index) => { return { ...app, originalIndex: index, breadcrumb: getAppBreadcrumbOpt(app.id) }; }).sort((a, b) => a.breadcrumb.localeCompare(b.breadcrumb));
    const colorSequence = ['bg-box-red', 'bg-box-blue', 'bg-box-green', 'bg-box-orange'];
    
    let tableHtml = sortedApps.filter(app => { if (filterVal === 'ROOT') return app.parentId === null; if (filterVal !== 'ALL') return isDescendantOpt(app.id, filterVal); return true; }).map((app, index) => {
        let levelText = ''; let baseType = (app.type && app.type.includes('_')) ? app.type.split('_')[0] : app.type;
        if(!app.parentId) { let typeDesc = "RIGHT"; if(baseType === "large-red") typeDesc = "LEFT"; if(baseType === "bottom-tab") typeDesc = "BOTTOM"; levelText = `<b style="color:var(--primary-red)">ROOT (${typeDesc})</b>`; } 
        else { let pathArr = app.breadcrumb.split(' > '); pathArr.pop(); levelText = `<div style="color:var(--text-muted); font-size:0.85rem; line-height:1.4;">${pathArr.join(' <i class="fas fa-angle-right" style="color:var(--primary-red); margin:0 3px;"></i> ')}</div>`; }
        let reqAccess = (app.type && app.type.includes('_')) ? app.type.split('_')[1] : '';
        let accessBadge = reqAccess ? ` <span style="background:var(--primary-dark); padding:3px 6px; border-radius:4px; font-size:0.75rem;"><i class="fas ${reqAccess==='PRO'?'fa-star':'fa-crown'}"></i> ${reqAccess}</span>` : '';
        const typeLabel = `<span style="background:rgba(255,255,255,0.1); padding:4px 8px; border-radius:4px; font-weight:bold; border: 1px solid var(--border-color);">${app.contentType.toUpperCase()}</span>${accessBadge}`;
        
        let colorClass = colorSequence[index % colorSequence.length];
        let tableIcon = `<div class="${colorClass}" style="width:35px; height:35px; border-radius:8px; display:flex; justify-content:center; align-items:center; box-shadow:inset 0 1px 3px rgba(255,255,255,0.2), 0 2px 5px rgba(0,0,0,0.4);"><i class="fas ${app.icon}" style="color:#fff; font-size:1.1rem;"></i></div>`;
        
        return `<tr><td>${levelText}</td><td>${tableIcon}</td><td><b>${app.title}</b> ${app.badge ? `<span style="color:var(--primary-red); font-size:0.8rem; margin-left:5px;">[${app.badge}]</span>`:''}</td><td>${typeLabel}</td><td><div class="action-cell" style="justify-content:center;"><button class="action-btn btn-edit" onclick="editApp('${app.id}')"><i class="fas fa-edit"></i></button> <button class="action-btn btn-delete" onclick="deleteApp('${app.id}')"><i class="fas fa-trash"></i></button></div></td></tr>`;
    }).join('');
