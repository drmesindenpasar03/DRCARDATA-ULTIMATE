window.saveApp = function() {
    const appId = document.getElementById('formAppId').value; const contentType = document.getElementById('formAppContentType').value; let isNew = (appId === ''); let finalContent = '';
    if (contentType === 'html') { finalContent = document.getElementById('formAppContent').value; } 
    else if (['pdf','web','mp4','image'].includes(contentType)) { finalContent = document.getElementById('formAppUrl').value; if (!finalContent) return appAlert("Target Source URL is required!", "Field Required", "warning"); }
    const parentId = document.getElementById('formAppParent').value || null;
    let baseType = parentId ? null : document.getElementById('formAppType').value; let finalType = baseType;
    if (!isNew) { let oldApp = appsData.find(a => a.id === appId); let oldAccess = (oldApp.type && oldApp.type.includes('_')) ? oldApp.type.split('_')[1] : ''; if(oldAccess) { finalType = baseType ? baseType + '_' + oldAccess : '_' + oldAccess; } }
    const appObj = { id: isNew ? 'MENU_' + Date.now() : appId, parentId: parentId, title: document.getElementById('formAppTitle').value, type: finalType, icon: document.getElementById('formAppIcon').value || 'fa-folder', badge: document.getElementById('formAppBadge').value, contentType: contentType, content: finalContent };
    if(!appObj.title) return appAlert("Module Name is required!", "Field Required", "warning");
    if(!isNew) { const index = appsData.findIndex(a => a.id === appId); if(index !== -1) appsData[index] = appObj; } else { appsData.push(appObj); }
    updateAppDictionary(); document.getElementById('appFormContainer').style.display = 'none'; window.renderAdminAppTable(); renderDynamicApps(); 
    if(menuStack.length > 0) renderCurrentMenuState(); if (isNew && contentType === 'folder') { window.openMenu(appObj.id); }
    apiRequest('sync_apps', appsData).catch(err => console.error(err));
    if(typeof window.firebaseSyncData === 'function') window.firebaseSyncData('apps', appsData);
}

function deleteNodeRecursive(nodeId) {
    const children = appsData.filter(a => a.parentId === nodeId); children.forEach(child => deleteNodeRecursive(child.id));
    const index = appsData.findIndex(a => a.id === nodeId); if (index !== -1) { appsData.splice(index, 1); }
}

window.deleteApp = function(appId) {
    const index = appsData.findIndex(a => a.id === appId); if (index === -1) return; const app = appsData[index]; const hasChildren = appsData.some(a => a.parentId === app.id);
    let confirmMsg = `Apakah Anda yakin ingin menghapus "${app.title}" secara permanen dari Database?`;
    if(hasChildren) { confirmMsg = `PERINGATAN! "${app.title}" masih berisi Sub-Menu/Folder lain di dalamnya.\n\nApakah Anda yakin ingin menghapus folder ini BESERTA SELURUH ISINYA dari Database?`; }
    appConfirm(confirmMsg, function(agreed) {
        if(agreed) {
            deleteNodeRecursive(appId); updateAppDictionary();
            const isCurrentDeleted = menuStack.some(m => m.id === appId); if(isCurrentDeleted) { menuStack = []; document.getElementById('detailScreen').style.display = 'none'; }
            window.renderAdminAppTable(); renderDynamicApps(); if(menuStack.length > 0) renderCurrentMenuState(); 
            apiRequest('sync_apps', appsData).catch(err => console.error(err));
            if(typeof window.firebaseSyncData === 'function') window.firebaseSyncData('apps', appsData);
        }
    });
}

