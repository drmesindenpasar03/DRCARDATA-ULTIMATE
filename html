window.exportToExcel = function() {
    if(typeof XLSX === 'undefined') return appAlert("Library Excel belum termuat. Pastikan koneksi internet stabil.", "Error", "error");
    let wb = XLSX.utils.book_new();
    let wsUsers = XLSX.utils.json_to_sheet(usersData); XLSX.utils.book_append_sheet(wb, wsUsers, "Users");
    let wsApps = XLSX.utils.json_to_sheet(appsData); XLSX.utils.book_append_sheet(wb, wsApps, "Modules");
    let wsConfig = XLSX.utils.json_to_sheet([headerConfig]); XLSX.utils.book_append_sheet(wb, wsConfig, "Config");
    let wsBilling = XLSX.utils.json_to_sheet([{ paymentInfo: window.billingConfig.paymentInfo, packages: JSON.stringify(window.billingConfig.packages) }]); XLSX.utils.book_append_sheet(wb, wsBilling, "Billing");
    let fileName = "DrCardata_Backup_" + new Date().toISOString().split('T')[0] + ".xlsx"; XLSX.writeFile(wb, fileName);
    appAlert("Backup berhasil! File Excel telah diunduh ke perangkat Anda.", "Backup Sukses", "success");
}

window.importFromExcel = function(e) {
    let file = e.target.files[0]; if(!file) return;
    let reader = new FileReader();
    reader.onload = function(evt) {
        let data = new Uint8Array(evt.target.result); let wb = XLSX.read(data, {type: 'array'});
        appConfirm("PERINGATAN!\nMengimpor data dari Excel akan MENIMPA (Overwrite) data di aplikasi saat ini dan secara otomatis tersinkronisasi ke Google Sheets. Lanjutkan?", async function(yes) {
            if(yes) {
                document.getElementById('loadingOverlay').style.display = 'flex';
                try {
                    let hasUpdate = false;
                    if(wb.Sheets["Users"]) {
                        let importedUsers = XLSX.utils.sheet_to_json(wb.Sheets["Users"]);
                        if(importedUsers.length > 0) {
                            importedUsers.forEach(u => { if(typeof u.devices !== 'string') u.devices = JSON.stringify(u.devices || []); });
                            usersData = importedUsers; await apiRequest('sync_users', usersData);
                            if(typeof window.firebaseSyncData === 'function') window.firebaseSyncData('users', usersData);
                            hasUpdate = true;
                        }
                    }
                    if(wb.Sheets["Modules"]) {
                        let importedApps = XLSX.utils.sheet_to_json(wb.Sheets["Modules"]);
                        if(importedApps.length > 0) {
                            appsData = importedApps; updateAppDictionary(); await apiRequest('sync_apps', appsData); 
                            if(typeof window.firebaseSyncData === 'function') window.firebaseSyncData('apps', appsData);
                            hasUpdate = true;
                        }
                    }
                    if(wb.Sheets["Config"]) {
                        let importedConfig = XLSX.utils.sheet_to_json(wb.Sheets["Config"]);
                        if(importedConfig.length > 0) {
                            headerConfig = importedConfig[0]; await apiRequest('sync_config', headerConfig); 
                            if(typeof window.firebaseSyncData === 'function') window.firebaseSyncData('config', headerConfig);
                            hasUpdate = true;
                        }
                    }
                    
                    document.getElementById('loadingOverlay').style.display = 'none';
                    if(hasUpdate) {
                        appAlert("Data berhasil dipulihkan dari Excel dan disinkronkan secara Real-Time!", "Restore Sukses", "success");
                        renderAdminUserTable(); renderAdminAppTable(); renderDynamicApps(); applyHeaderConfig();
                    } else { appAlert("File Excel kosong atau format tidak dikenali.", "Format Tidak Valid", "warning"); }
                } catch(err) { document.getElementById('loadingOverlay').style.display = 'none'; appAlert("Kesalahan saat membaca Excel: " + err.message, "Import Error", "error"); }
            } document.getElementById('excelFileInput').value = ''; 
        });
    }; reader.readAsArrayBuffer(file);
}
